# flyctl launch added from .gitignore
# Binaries (but not source directories)
bin/
**/*.exe
**/*.exe~
**/*.dll
**/*.so
**/*.dylib
bot

# Test binary, built with `go test -c`
**/*.test

# Output of the go coverage tool
**/*.out

# Go workspace file
**/go.work

# Environment variables
**/.env
**/.env.local
**/.env.*.local

# Logs
**/logs
**/*.log

# Memory system data (runtime data, not source code)
workplace/memory/
memory/

# Configuration with sensitive data
**/config/cron.json
**/config/cron_history.json

# IDE
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/*~

# OS
**/.DS_Store
**/Thumbs.db

# Docker
**/docker-compose.override.yml

# Temporary files
**/tmp
**/temp
**/*.tmp

# Build artifacts
**/dist
**/build
fly.toml
