# Required Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional Configuration
# Model to use for LLM requests (default: google/gemini-2.5-flash-lite)
MODEL_NAME=google/gemini-2.5-flash-lite

# Timeout for shell command execution in seconds (default: 30)
SHELL_TIMEOUT=30

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Memory System Configuration
# Token threshold for triggering emergency summarization during active conversation (default: 50000)
MEMORY_TOKEN_THRESHOLD=50000

# Topic file size threshold in bytes for subdivision (default: 102400 = 100KB)
TOPIC_SIZE_THRESHOLD=102400

# Notes cleanup configuration
# Enable automatic cleanup of old notes (default: true)
NOTES_CLEANUP_ENABLED=true

# Maximum age in days for notes without modifications (default: 30)
NOTES_MAX_AGE_DAYS=30

# Retention days for completed notes (default: 7)
NOTES_COMPLETED_RETENTION_DAYS=7

# Maximum age in days for scratchpad notes (default: 7)
NOTES_SCRATCHPAD_MAX_AGE_DAYS=7

# Cron schedule for daily maintenance (default: "0 4 * * *" = 4:00 AM daily)
DAILY_MAINTENANCE_TIME=0 4 * * *
